# Dotlad's light README demo. Run from the repository root with:
# vhs .github/assets/demo/cli-light.tape

Require bash
Require git

Output .github/assets/demo/cli-light.gif
Set Theme "Github"
Source .github/assets/demo/cli-settings.tape

Env DOTLAD_COLOR_SCHEME "light"

Source .github/assets/demo/cli-actions.tape
