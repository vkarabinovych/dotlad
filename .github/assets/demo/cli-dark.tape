# Dotlad's dark README demo. Run from the repository root with:
# vhs .github/assets/demo/cli-dark.tape

Require bash
Require git

Output .github/assets/demo/cli-dark.gif
Set Theme "Dracula+"
Source .github/assets/demo/cli-settings.tape

Env DOTLAD_COLOR_SCHEME "dark"

Source .github/assets/demo/cli-actions.tape
