root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# shfmt options. These are ignored by editors and formatters that do not
# understand them.
shell_variant = bash
switch_case_indent = true

[*.{md,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
